<!DOCTYPE html>
<html>
  <head>
    <title>ChatPro | Premium Real-time Experience</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/trix@2.1.12/dist/trix.css">
    <script src="https://unpkg.com/trix@2.1.12/dist/trix.umd.min.js"></script>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="app-body">
    <nav class="navbar">
      <div class="div-container nav-wrapper">
        <div class="nav-left">
          <%= link_to root_path, class: "nav-logo" do %>
            <span class="logo-icon">💬</span>
            <span class="logo-text">ChatPro</span>
          <% end %>
        </div>
        
        <div class="nav-right">
          <% if user_signed_in? %>
            <div class="user-info">
              <span class="user-badge"></span>
              <span class="user-email"><%= current_user.email %></span>
            </div>
            <% if current_user.admin? %>
              <%= link_to "Audit Logs", audit_logs_path, class: "btn btn-secondary" %>
            <% end %>
            <%= link_to "Logout", destroy_user_session_path,
                  data: { turbo_method: :delete },
                  class: "btn btn-logout" %>
          <% else %>
             <%= link_to "Login", new_user_session_path, class: "btn btn-login" %>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="main-content">
      <div class="div-container">
        <%= yield %>
      </div>
    </main>
  </body>
</html>
